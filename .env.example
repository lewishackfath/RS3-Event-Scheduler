APP_NAME="Clan Event Scheduler"
APP_URL="https://events.example.com"
APP_ENV="production"
APP_DEBUG=false

DB_HOST="127.0.0.1"
DB_PORT="3306"
DB_DATABASE="shared_clan_database"
DB_USERNAME="db_user"
DB_PASSWORD="db_pass"
DB_CHARSET="utf8mb4"

CLAN_ID=1
CLAN_NAME="Example Clan"
DEFAULT_TIMEZONE="Australia/Sydney"
DEFAULT_DISCORD_CHANNEL_ID="123456789012345678"

BRAND_LOGO_URL="https://events.example.com/assets/logo.png"
BRAND_HEADER_IMAGE_URL="https://events.example.com/assets/header.jpg"
BRAND_EMBED_COLOUR="#5865F2"
BRAND_FOOTER_TEXT="Example Clan Events"
BRAND_BACKGROUND_IMAGE_URL=""

DISCORD_BOT_TOKEN="your_discord_bot_token"
DISCORD_CLIENT_ID="your_discord_oauth_client_id"
DISCORD_CLIENT_SECRET="your_discord_oauth_client_secret"
DISCORD_REDIRECT_URI="https://events.example.com/oauth_callback.php"
DISCORD_OAUTH_SCOPE="identify guilds.members.read"
DISCORD_GUILD_ID="123456789012345678"
ADMIN_ROLE_IDS="111111111111111111,222222222222222222"
